SPRING_PROFILES_ACTIVE=dev

SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/<db>
SUPABASE_DB_USERNAME=<username>
SUPABASE_DB_PASSWORD=<password>

# External raw PEM URLs for JWT keys
JWT_PRIVATE_KEY_PATH=https://<your-key-manager>/jwt-private.pem
JWT_PUBLIC_KEY_PATH=https://<your-key-manager>/jwt-public.pem

JWT_AUDIENCE=your-application
JWT_ISSUER=auth-service
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000
AUTH_ALLOWED_ROLES=ADMIN,CUSTOMER,SUPPORT,SELLER
CORS_ALLOWED_ORIGINS=http://localhost:3000
SERVER_PORT=8080

DB_POOL_MAX=5
DB_POOL_MIN=2
DB_POOL_CONN_TIMEOUT_MS=30000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000

REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/auth
REFRESH_TOKEN_COOKIE_MAX_AGE=604800
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAME_SITE=None